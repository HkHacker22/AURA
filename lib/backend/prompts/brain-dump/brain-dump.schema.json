{
  "type": "object",
  "properties": {
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "title": { "type": "string", "description": "Task title" },
          "description": { "type": "string", "description": "Optional context" },
          "priority": { "type": "string", "enum": ["high", "medium", "low"] },
          "tags": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["title"]
      }
    },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "date": { "type": "string", "description": "ISO 8601 date" },
          "time": { "type": "string" }
        },
        "required": ["title"]
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "content": { "type": "string" }
        },
        "required": ["content"]
      }
    }
  },
  "required": ["tasks", "events", "notes"]
}